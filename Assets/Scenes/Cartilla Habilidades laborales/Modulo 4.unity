  correctSfx: {fileID: 8300000, guid: 1ef94579c8716134185a2bd524c3a95b, type: 3}
  errorSfx: {fileID: 8300000, guid: 4956605316b8dd945a932e942737344a, type: 3}
  activityName: "Comunicaci\xF3n"
  activityHint: 
  occupiedMsg: "Este espacio ya est\xE1 ocupado."
  correctMsg: "\xA1Correcto!"
  primarioWrongHint: "Este sector se encarga de obtener materias primas de la naturaleza,
    como el algod\xF3n, la madera o los minerales.\nPiensa si esta \xE1rea extrae
    recursos naturales o si hace otro tipo de trabajo dentro de la empresa."
  secundarioWrongHint: "El sector secundario se encarga de transformar materias primas
    en productos, por ejemplo fabricar ropa, alimentos procesados o autom\xF3viles.\nPreg\xFAntate
    si esta \xE1rea fabrica o produce algo f\xEDsicamente."
  terciarioWrongHint: "El sector terciario se dedica a ofrecer servicios, como administraci\xF3n,
    ventas, comunicaci\xF3n o atenci\xF3n al cliente.\nPiensa si esta \xE1rea apoya
    el funcionamiento de la empresa ofreciendo un servicio en lugar de fabricar productos."
